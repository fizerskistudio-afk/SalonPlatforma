# Kopirati kao .env.tenant-isolation.local i ne commitovati.
TENANT_QA_BASE_URL=http://localhost:3000

# Slugovi imaju podrazumevane vrednosti, ali ih možeš eksplicitno postaviti.
TENANT_QA_MIKA_SLUG=mika-berberin
TENANT_QA_LUMIERE_SLUG=lumiere-studio

# Dovoljna su dva owner naloga za osnovni RLS test.
TENANT_QA_MIKA_OWNER_EMAIL=
TENANT_QA_MIKA_OWNER_PASSWORD=
TENANT_QA_LUMIERE_OWNER_EMAIL=
TENANT_QA_LUMIERE_OWNER_PASSWORD=

# Opcionalno: manager uloge.
TENANT_QA_MIKA_MANAGER_EMAIL=
TENANT_QA_MIKA_MANAGER_PASSWORD=
TENANT_QA_LUMIERE_MANAGER_EMAIL=
TENANT_QA_LUMIERE_MANAGER_PASSWORD=

# Opcionalno: staff uloge.
TENANT_QA_MIKA_STAFF_EMAIL=
TENANT_QA_MIKA_STAFF_PASSWORD=
TENANT_QA_LUMIERE_STAFF_EMAIL=
TENANT_QA_LUMIERE_STAFF_PASSWORD=

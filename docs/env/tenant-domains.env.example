# Dodaj u lokalni .env.local radi testiranja tenant poddomena.
# Nemoj brisati postojeće Supabase, Google ili Resend promenljive.

PLATFORM_ROOT_DOMAIN=localhost:3000
PLATFORM_ROOT_PROTOCOL=http

